---
export interface Props {
  showLinks?: boolean;
}

const { showLinks = true } = Astro.props;
---

<footer>
  <div class="wrap">
    <div class="frow">
      <div class="fcol">
        <a class="logo" href="/">
          <svg viewBox="0 0 467 467" aria-hidden="true"><defs><linearGradient id="fg2" x2="1" gradientUnits="userSpaceOnUse" gradientTransform="matrix(-0.78,179.95,-222.488,-0.964,234.62,167.69)"><stop offset="0" stop-color="#f7b52c"></stop><stop offset="1" stop-color="#e95513"></stop></linearGradient></defs><path fill="url(#fg2)" d="m347.1 196.1c-7.8-11.8-17.3-24.6-28.6-37.3 0 0-34.2-39.3-28.5-100.4 0 0-133.7 51.7-136.2 160 0 0-19.7-31.1-15.6-89.4 0 0-41.9 41-49.1 106.3-40.1 14.6-72.6 48.6-72.6 84 0 49.3 51 89.4 114.3 90.2-46.8-8.4-81.6-40.7-81.6-79.5 0-25.6 15.3-48.5 39.3-63.5 1 14.9 4 30.6 9.5 47.1 0 0 22.1 73.7 103.4 92.7 24.3 5.7 50 4.1 72.9-6 25.8-11.3 54-35.4 55.3-86.5 0 0 1.9-52.9-30.7-79.4 0 0 42.3 96.7-34.2 126.3-24.4 9.5-51.6 9.1-75.8-0.9-33.2-13.8-74.4-49-67.3-139.5 0 0 19.1 66.4 61 90.4 0 0-37.8-112.8 75.4-190.7 0 0 10.7 40.6 37 65.2 7.7 7.3 79.5 61.5 64.6 155.4 14.2-18.1 26.3-61.2 14.9-93.9 0 0-2.7-6.9-8.3-17.9 27.9 7.1 52.4 29.3 54.2 82.1 1.6 44.5-31.1 82.5-75 97.8 59.9-7.2 106.1-53 106.1-108.6 0-55.5-43.8-98.8-104.4-104.1z"></path></svg>
          BurnCloud
        </a>
        <p>Open source LLM API gateway.</p>
      </div>
      <div class="fcol">
        <h4>Product</h4>
        <a href="/models/">Models</a>
        <a href="/pricing/">Pricing</a>
        <a href="/security/">Security</a>
        <a href="/compare/">Compare</a>
      </div>
      <div class="fcol">
        <h4>Resources</h4>
        <a href="/docs/quickstart/">Quickstart</a>
        <a href="/blog/">Blog</a>
        <a href="#">GitHub</a>
      </div>
      <div class="fcol">
        <h4>Company</h4>
        <a href="#">About</a>
        <a href="#">Contact</a>
      </div>
    </div>
    <div class="fbot">
      <p>© 2026 BurnCloud. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  footer .frow { display: grid; grid-template-columns: 1.5fr repeat(3, 1fr); gap: 40px; }
  footer .fcol { display: flex; flex-direction: column; gap: 12px; }
  footer .fcol h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); font-weight: 600; }
  footer .fcol a { font-size: 14px; color: var(--muted); }
  footer .fcol a:hover { color: var(--text); }
  footer .fcol p { font-size: 14px; color: var(--muted); }
  footer .fbot { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); text-align: center; }
  footer .fbot p { font-size: 13px; color: var(--muted); }
  
  @media (max-width: 768px) {
    footer .frow { grid-template-columns: 1fr 1fr; }
  }
</style>