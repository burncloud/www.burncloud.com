---
export interface Props {
  title: string;
  description?: string;
  pageStyle?: string;
}

const { title, description = "Access Claude, GPT, Gemini, DeepSeek at lower cost. Open source, auditable, verified. One API key.", pageStyle = 'home' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={Astro.url.href}>
  
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="BurnCloud">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  
  <!-- Critical CSS inlined -->
  <style is:inline>
:root{--bg:#fff;--surface:#f7f7f8;--border:#e5e5e5;--text:#0a0a0f;--muted:#6b6b7b;--accent:#6366f1;--accent-hover:#4f46e5;--accent-tint:#eef2ff;--green:#16a34a;--green-tint:#f0fdf4;--red:#dc2626;--code-bg:#f4f4f5;--sans:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,Roboto,sans-serif;--mono:ui-monospace,'SF Mono',Menlo,Consolas,monospace;--maxw:960px}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.6}
a{color:inherit;text-decoration:none}
h1,h2,h3{font-weight:700;letter-spacing:-.025em;line-height:1.08;color:var(--text)}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px}
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.85);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}
nav .wrap{display:flex;align-items:center;justify-content:space-between;height:60px}
.logo{display:flex;align-items:center;gap:9px;font-weight:700;font-size:16px}
.logo svg{width:20px;height:20px;display:block}
.nav-links{display:flex;align-items:center;gap:26px}
.nav-links a.link{font-size:14px;color:var(--muted);font-weight:500}
footer{border-top:1px solid var(--border);padding:32px 0}
footer .wrap{display:flex;flex-direction:column;gap:24px}
footer .frow{display:grid;grid-template-columns:1.5fr repeat(3,1fr);gap:40px}
footer .fcol{display:flex;flex-direction:column;gap:12px}
footer .fcol h4{font-size:13px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);font-weight:600}
footer .fcol a{font-size:14px;color:var(--muted)}
footer .fbot{margin-top:32px;padding-top:24px;border-top:1px solid var(--border);text-align:center}
footer .fbot p{font-size:13px;color:var(--muted)}
@media(max-width:768px){footer .frow{grid-template-columns:1fr 1fr}}
@media(max-width:560px){footer .frow{grid-template-columns:1fr}}
  </style>
  
  <!-- Shared CSS -->
  <link rel="stylesheet" href="/styles/base.css">
  <link rel="stylesheet" href="/styles/components.css">
  <link rel="stylesheet" href="/styles/responsive.css">
  
  <!-- Page-specific CSS -->
  <link rel="stylesheet" href={`/styles/pages/${pageStyle}.css`}>
</head>
<body>
  <slot />
</body>
</html>