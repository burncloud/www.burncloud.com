---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Access Claude, GPT, Gemini, DeepSeek at lower cost. Open source, auditable, verified. One API key." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={Astro.url.href}>
  
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:site_name" content="BurnCloud">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  
  <!-- All CSS inlined in head for instant loading -->
  <style is:inline>
    :root {
      --bg: #ffffff;
      --surface: #f7f7f8;
      --border: #e5e5e5;
      --text: #0a0a0f;
      --muted: #6b6b7b;
      --accent: #6366f1;
      --accent-hover: #4f46e5;
      --accent-tint: #eef2ff;
      --green: #16a34a;
      --green-tint: #f0fdf4;
      --red: #dc2626;
      --red-tint: #fef2f2;
      --code-bg: #f4f4f5;
      --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, Roboto, 'Helvetica Neue', Arial, sans-serif;
      --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Cascadia Code', Menlo, Consolas, monospace;
      --maxw: 960px;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
    }
    a { color: inherit; text-decoration: none; }
    ::selection { background: var(--accent); color: #fff; }
    
    .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }
    h1, h2, h3 { font-weight: 700; letter-spacing: -0.025em; line-height: 1.08; color: var(--text); }
    
    /* ---- buttons ---- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 600;
      padding: 10px 18px;
      border-radius: 8px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.1s ease;
      white-space: nowrap;
    }
    .btn:active { transform: translateY(1px); }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-outline { background: var(--bg); color: var(--text); border-color: var(--border); }
    .btn-outline:hover { border-color: var(--muted); background: var(--surface); }
    .btn-lg { padding: 14px 26px; font-size: 15px; border-radius: 9px; }
    
    /* ---- nav ---- */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    nav .wrap { display: flex; align-items: center; justify-content: space-between; height: 60px; }
    .logo { display: flex; align-items: center; gap: 9px; font-weight: 700; font-size: 16px; letter-spacing: -0.02em; }
    .logo svg { width: 20px; height: 20px; display: block; }
    .nav-links { display: flex; align-items: center; gap: 26px; }
    .nav-links a.link { font-size: 14px; color: var(--muted); font-weight: 500; transition: color 0.15s ease; }
    .nav-links a.link:hover { color: var(--text); }
    .ext { font-size: 0.85em; opacity: 0.7; }
    
    /* ---- hero ---- */
    .hero { text-align: center; padding: 96px 0 72px; }
    .hero h1 { font-size: clamp(44px, 8vw, 72px); letter-spacing: -0.04em; line-height: 1.0; }
    .hero .sub { font-size: 18px; color: var(--muted); max-width: 560px; margin: 24px auto 0; line-height: 1.6; }
    .pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin: 32px auto 0; max-width: 620px; }
    .pill { font-family: var(--mono); font-size: 13px; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 999px; padding: 6px 14px; }
    .hero-cta { display: flex; justify-content: center; gap: 12px; margin-top: 36px; flex-wrap: wrap; }
    
    .verify-box {
      max-width: 620px;
      margin: 44px auto 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      font-family: var(--mono);
      font-size: 13px;
      text-align: left;
      color: var(--text);
    }
    .verify-box .vcheck { flex: 0 0 auto; width: 22px; height: 22px; border-radius: 50%; background: var(--green-tint); color: var(--green); display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; }
    .verify-box .vtext { flex: 1; line-height: 1.5; color: var(--muted); }
    .verify-box .vtext strong { color: var(--text); font-weight: 600; }
    .verify-box .vproof { flex: 0 0 auto; color: var(--accent); font-weight: 600; font-family: var(--sans); font-size: 13px; }
    .verify-box .vproof:hover { text-decoration: underline; }
    
    /* ---- proof bar ---- */
    .proofbar { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--surface); }
    .proofbar .wrap { padding: 28px 24px; text-align: center; }
    .proofbar .label { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
    .proofbar .frameworks { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px 28px; font-family: var(--mono); font-size: 14px; color: var(--text); font-weight: 500; }
    .proofbar .frameworks span { opacity: 0.75; }
    
    /* ---- section ---- */
    .sec { padding: 88px 0; border-bottom: 1px solid var(--border); }
    .sec-head { text-align: center; max-width: 640px; margin: 0 auto 52px; }
    .sec-head h2 { font-size: clamp(30px, 4.5vw, 42px); letter-spacing: -0.03em; }
    .sec-head p { color: var(--muted); font-size: 17px; margin-top: 14px; }
    
    /* ---- problem cards ---- */
    .cards2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .pcard { border: 1px solid var(--border); border-radius: 12px; padding: 28px; background: var(--bg); }
    .pcard.bad { border-top: 3px solid var(--red); }
    .pcard.good { border-top: 3px solid var(--green); }
    .pcard h3 { font-size: 18px; margin-bottom: 20px; }
    .pcard ul { list-style: none; display: flex; flex-direction: column; gap: 13px; }
    .pcard li { display: flex; align-items: flex-start; gap: 11px; font-size: 15px; color: var(--text); }
    .pcard li .ic { flex: 0 0 auto; font-weight: 700; line-height: 1.5; }
    .pcard.bad li { color: var(--muted); }
    .pcard.bad li .ic { color: var(--red); }
    .pcard.good li .ic { color: var(--green); }
    
    /* ---- flow ---- */
    .flow { display: flex; align-items: stretch; justify-content: center; gap: 0; flex-wrap: wrap; }
    .flow-node { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 18px 22px; text-align: center; min-width: 150px; display: flex; flex-direction: column; justify-content: center; }
    .flow-node.verified { border-color: var(--green); background: var(--green-tint); }
    .flow-node .fn-title { font-weight: 600; font-size: 15px; }
    .flow-node .fn-sub { font-size: 12px; color: var(--muted); margin-top: 4px; font-family: var(--mono); }
    .flow-node.verified .fn-sub { color: var(--green); }
    .flow-arrow { display: flex; align-items: center; padding: 0 14px; color: var(--muted); font-size: 18px; }
    .flow-note { text-align: center; margin-top: 32px; font-family: var(--mono); font-size: 14px; color: var(--muted); }
    .flow-note strong { color: var(--text); font-weight: 500; }
    
    /* ---- pricing table ---- */
    .ptable-wrap { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    table.pricing { width: 100%; border-collapse: collapse; font-size: 15px; }
    table.pricing th, table.pricing td { text-align: left; padding: 16px 22px; }
    table.pricing th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); font-weight: 600; background: var(--surface); border-bottom: 1px solid var(--border); }
    table.pricing td { border-bottom: 1px solid var(--border); }
    table.pricing tr:last-child td { border-bottom: 0; }
    table.pricing .num { text-align: right; font-family: var(--mono); font-size: 14px; }
    table.pricing .model { font-weight: 600; }
    table.pricing .official { color: var(--muted); }
    table.pricing .save { color: var(--green); font-weight: 600; text-align: right; font-family: var(--mono); }
    .price-cap { text-align: center; margin-top: 20px; font-size: 14px; color: var(--muted); }
    
    /* ---- code block ---- */
    .codewrap { max-width: 720px; margin: 0 auto; }
    pre.code { background: var(--code-bg); border: 1px solid var(--border); border-radius: 12px; padding: 26px 28px; font-family: var(--mono); font-size: 14px; line-height: 1.8; overflow-x: auto; }
    pre.code .cm { color: var(--muted); }
    pre.code .str { color: var(--green); }
    pre.code .fn { color: var(--accent); }
    pre.code .changed { background: rgba(99,102,241,0.1); display: inline-block; width: 100%; border-radius: 3px; }
    pre.code .mk { color: var(--accent); }
    .code-cap { text-align: center; margin-top: 18px; font-size: 14px; color: var(--green); font-weight: 500; }
    .code-cap .ic { font-weight: 700; }
    
    /* ---- steps ---- */
    .steps3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .scard { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 26px; }
    .scard .snum { font-family: var(--mono); font-size: 13px; color: var(--accent); font-weight: 600; }
    .scard h3 { font-size: 18px; margin: 14px 0 8px; }
    .scard p { font-size: 14px; color: var(--muted); }
    
    /* ---- faq ---- */
    .faq { max-width: 720px; margin: 0 auto; }
    .faq details { border-bottom: 1px solid var(--border); }
    .faq details:first-child { border-top: 1px solid var(--border); }
    .faq summary { list-style: none; cursor: pointer; padding: 22px 0; display: flex; align-items: center; justify-content: space-between; gap: 20px; font-size: 17px; font-weight: 600; color: var(--text); }
    .faq summary::-webkit-details-marker { display: none; }
    .faq summary .sign { flex: 0 0 auto; color: var(--accent); font-size: 20px; line-height: 1; transition: transform 0.25s ease; }
    .faq details[open] summary .sign { transform: rotate(45deg); }
    .faq .ans { padding: 0 40px 24px 0; color: var(--muted); font-size: 15px; line-height: 1.7; }
    .faq .ans a { color: var(--accent); font-weight: 500; }
    .faq .ans a:hover { text-decoration: underline; }
    
    /* ---- cta ---- */
    .ctasec { background: var(--accent-tint); text-align: center; padding: 88px 0; }
    .ctasec h2 { font-size: clamp(32px, 5vw, 46px); letter-spacing: -0.03em; }
    .ctasec .cap { margin-top: 22px; font-size: 14px; color: var(--muted); }
    
    /* ---- footer ---- */
    footer { border-top: 1px solid var(--border); padding: 32px 0; }
    footer .wrap { display: flex; flex-direction: column; gap: 24px; }
    footer .frow { display: grid; grid-template-columns: 1.5fr repeat(3, 1fr); gap: 40px; }
    footer .fcol { display: flex; flex-direction: column; gap: 12px; }
    footer .fcol h4 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); font-weight: 600; }
    footer .fcol a { font-size: 14px; color: var(--muted); }
    footer .fcol a:hover { color: var(--text); }
    footer .fcol p { font-size: 14px; color: var(--muted); }
    footer .fbot { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); text-align: center; }
    footer .fbot p { font-size: 13px; color: var(--muted); }
    
    /* ---- responsive ---- */
    @media (max-width: 768px) {
      .sec { padding: 60px 0; }
      .hero { padding: 64px 0 52px; }
      .cards2 { grid-template-columns: 1fr; }
      .steps3 { grid-template-columns: 1fr; }
      .flow { flex-direction: column; align-items: center; }
      .flow-node { width: 100%; max-width: 320px; }
      .flow-arrow { transform: rotate(90deg); padding: 8px 0; }
      .verify-box { flex-wrap: wrap; }
      .verify-box .vproof { width: 100%; }
      .nav-links { gap: 16px; }
      .nav-links a.link.hide-sm { display: none; }
      table.pricing th, table.pricing td { padding: 13px 14px; }
      table.pricing .hide-sm { display: none; }
      footer .frow { grid-template-columns: 1fr 1fr; }
    }
    
    @media (max-width: 560px) {
      footer .frow { grid-template-columns: 1fr; }
      .nav-links a.link.hide-sm { display: none; }
      .nav-links { gap: 14px; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>