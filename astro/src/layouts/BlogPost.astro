---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  tag?: string;
  publishDate?: string;
  readTime?: string;
}

const { title, description, tag = 'Guide', publishDate = 'Jun 2026', readTime = '5 min' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/blog">Blog</a>
      <span class="sep">/</span>
      <span class="cur">{title.split('|')[0].trim()}</span>
    </div>
  </nav>

  <main class="layout">
    <article class="article">
      <header class="ahead">
        <span class="tag">{tag}</span>
        <h1>{title.split('|')[0].trim()}</h1>
        <div class="ameta">
          <span>{publishDate}</span>
          <span class="dot">·</span>
          <span>{readTime} read</span>
        </div>
      </header>
      
      <div class="abody">
        <slot />
      </div>
    </article>
    
    <aside class="sidebar">
      <div class="sbox cta">
        <div class="big">Start Free</div>
        <p class="price">$5 minimum</p>
        <a href="#" class="btn btn-primary btn-block">Get API Key</a>
      </div>
    </aside>
  </main>

  <Footer />
</BaseLayout>

<style is:inline>
  .crumb{border-bottom:1px solid var(--border);background:var(--surface);}
  .crumb .wrap{padding:12px 24px;font-size:13px;color:var(--muted);font-family:var(--mono);display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
  .crumb a:hover{color:var(--text);}
  .crumb .sep{opacity:.5;}
  .crumb .cur{color:var(--text);}
  
  .layout{display:grid;grid-template-columns:1fr 300px;gap:52px;padding:48px 0 40px;align-items:start;max-width:var(--maxw);margin:0 auto;padding-left:24px;padding-right:24px;}
  
  .article .tag{display:inline-block;font-family:var(--mono);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;padding:4px 10px;border-radius:999px;color:var(--accent);background:var(--accent-tint);}
  .article h1{font-size:clamp(30px,4.4vw,40px);letter-spacing:-.035em;margin:16px 0 14px;line-height:1.1;}
  .ameta{font-family:var(--mono);font-size:13px;color:var(--muted);display:flex;gap:10px;flex-wrap:wrap;align-items:center;border-bottom:1px solid var(--border);padding-bottom:24px;}
  .ameta .dot{opacity:.5;}
  
  .abody{padding-top:32px;}
  .abody h2{font-size:25px;letter-spacing:-.025em;margin:48px 0 16px;scroll-margin-top:76px;}
  .abody p{font-size:17px;line-height:1.8;color:#2a2a33;}
  .abody p+p{margin-top:16px;}
  .abody ul{margin:14px 0;padding-left:24px;}
  .abody li{font-size:17px;line-height:1.7;color:#2a2a33;margin-bottom:8px;}
  .abody a{color:var(--accent);font-weight:500;}
  .abody a:hover{text-decoration:underline;}
  .abody pre{background:var(--code-bg);padding:20px;border-radius:10px;overflow-x:auto;font-family:var(--mono);font-size:14px;line-height:1.6;}
  .abody code{font-family:var(--mono);background:var(--code-bg);padding:2px 6px;border-radius:4px;font-size:.92em;}
  .abody pre code{background:none;padding:0;}
  
  .sidebar{position:sticky;top:80px;}
  .sbox{border:1px solid var(--border);border-radius:12px;padding:20px;}
  .sbox.cta{background:var(--accent-tint);border-color:#dfe3ff;text-align:center;}
  .sbox .big{font-size:18px;font-weight:700;letter-spacing:-.02em;}
  .sbox .price{font-family:var(--mono);font-size:13px;color:var(--muted);margin:6px 0 16px;}
  
  @media (max-width:900px){
    .layout{grid-template-columns:1fr;gap:0;}
    .sidebar{position:static;margin-top:44px;}
  }
</style>