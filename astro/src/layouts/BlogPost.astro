---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  tag?: string;
  publishDate?: string;
  readTime?: string;
}

const { title, description, tag = 'Guide', publishDate = 'Jun 2026', readTime = '5 min' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/blog">Blog</a>
      <span class="sep">/</span>
      <span class="cur">{title.split('|')[0].trim()}</span>
    </div>
  </nav>

  <main class="layout">
    <article class="article">
      <header class="ahead">
        <span class="tag">{tag}</span>
        <h1>{title.split('|')[0].trim()}</h1>
        <div class="ameta">
          <span>{publishDate}</span>
          <span class="dot">·</span>
          <span>{readTime} read</span>
        </div>
      </header>
      
      <div class="abody">
        <slot />
      </div>
    </article>
    
    <aside class="sidebar">
      <div class="sbox cta">
        <div class="big">Start Free</div>
        <p class="price">$5 minimum</p>
        <a href="#" class="btn btn-primary btn-block">Get API Key</a>
      </div>
    </aside>
  </main>

  <Footer />
</BaseLayout>

