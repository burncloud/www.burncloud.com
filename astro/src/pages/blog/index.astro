---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const articles = [
  {
    slug: 'deepseek-v4-api-guide',
    title: 'DeepSeek V4 API Guide: Complete Setup 2026',
    excerpt: 'Everything you need to start calling DeepSeek V4 through an OpenAI-compatible endpoint.',
    tag: 'Tutorial',
    tagClass: 'tutorial',
    date: 'May 28, 2026',
    readTime: '8 min',
    featured: true
  },
  {
    slug: 'cheapest-llm-api-2026',
    title: 'Cheapest LLM API in 2026 - Complete Price Comparison',
    excerpt: 'Find the cheapest LLM API in 2026. Compare DeepSeek, Qwen, GPT, Claude prices.',
    tag: 'Guide',
    tagClass: 'guide',
    date: 'Jun 8, 2026',
    readTime: '6 min',
    featured: false
  },
  {
    slug: 'chinese-ai-models',
    title: 'Chinese AI Models: DeepSeek vs Qwen vs Doubao',
    excerpt: 'A head-to-head comparison of China top open-weight LLMs in 2026.',
    tag: 'Comparison',
    tagClass: 'comparison',
    date: 'Jun 2, 2026',
    readTime: '10 min',
    featured: false
  },
  {
    slug: 'cut-ai-costs',
    title: 'How to Cut Your LLM API Costs by 80%',
    excerpt: 'Five proven tactics to reduce your LLM spend without sacrificing quality.',
    tag: 'Guide',
    tagClass: 'guide',
    date: 'Jun 3, 2026',
    readTime: '7 min',
    featured: false
  },
  {
    slug: 'openai-sdk-compatible',
    title: 'OpenAI SDK Compatible APIs: Full List 2026',
    excerpt: 'Use Claude, Gemini, DeepSeek and more with the OpenAI SDK. Just change two lines.',
    tag: 'Guide',
    tagClass: 'guide',
    date: 'Jun 1, 2026',
    readTime: '7 min',
    featured: false
  },
  {
    slug: 'cheapest-llm-api',
    title: 'Cheapest LLM API 2026: Complete Price Comparison',
    excerpt: 'Every major LLM API ranked by real cost per 1M tokens.',
    tag: 'Guide',
    tagClass: 'guide',
    date: 'Jun 4, 2026',
    readTime: '6 min',
    featured: false
  }
];

const featured = articles.find(a => a.featured);
const regular = articles.filter(a => !a.featured);
---

<BaseLayout pageStyle="blog" title="BurnCloud Blog | LLM API Guides, Tutorials & AI News 2026" description="Developer guides, tutorials and industry analysis on LLM APIs. Learn how to reduce AI costs, compare models, and build better AI applications.">
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="cur">Blog</span>
    </div>
  </nav>

  <main>
    <section class="bhero" aria-labelledby="b-h1">
      <div class="wrap">
        <h1 id="b-h1">BurnCloud Blog</h1>
        <p>Guides, tutorials and analysis for developers building with LLMs.</p>
        <div class="cats" id="cats" role="tablist" aria-label="Filter by category">
          <button class="cat active" data-cat="all">All</button>
          <button class="cat" data-cat="tutorial">Tutorials</button>
          <button class="cat" data-cat="comparison">Comparisons</button>
          <button class="cat" data-cat="guide">Guides</button>
        </div>
      </div>
    </section>

    {featured && (
      <section aria-label="Featured article">
        <div class="wrap">
          <a class="featured" href={`/blog/${featured.slug}`} data-cat={featured.tagClass}>
            <div class="fimg"><span class="glyph">DeepSeek V4</span></div>
            <div class="fbody">
              <span class={`tag ${featured.tagClass}`}>{featured.tag}</span>
              <h2>{featured.title}</h2>
              <p class="excerpt">{featured.excerpt}</p>
              <div class="meta">{featured.date} · {featured.readTime} read</div>
              <span class="readmore">Read more</span>
            </div>
          </a>
        </div>
      </section>
    )}

    <section>
      <div class="wrap">
        <div class="gridhead">
          <h2>All Articles</h2>
        </div>
        <div class="agrid">
          {regular.map(article => (
            <a class="acard" href={`/blog/${article.slug}`} data-cat={article.tagClass}>
              <span class={`tag ${article.tagClass}`}>{article.tag}</span>
              <h3>{article.title}</h3>
              <p class="excerpt">{article.excerpt}</p>
              <div class="meta">
                <span>{article.date}</span>
                <span class="read">Read</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="ctasec" id="cta" aria-labelledby="cta-h2">
      <div class="wrap">
        <h2 id="cta-h2">Start building with BurnCloud</h2>
        <p class="cap">One API key for every model</p>
        <div class="btnrow"><a href="#" class="btn btn-primary btn-lg">Start Free</a></div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

