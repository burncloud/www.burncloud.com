---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const models = {
  'deepseek-v4-flash': {
    name: 'DeepSeek V4 Flash',
    provider: 'DeepSeek',
    input: '0.14',
    output: '0.28',
    context: '1M',
    maxOutput: '16K',
    latency: '210ms',
    description: 'The cheapest high-quality LLM with 1M context window',
    best: ['High-throughput agents', 'Bulk data processing', 'Long-document RAG', 'Real-time chat']
  },
  'deepseek-v4-pro': {
    name: 'DeepSeek V4 Pro',
    provider: 'DeepSeek',
    input: '0.435',
    output: '0.87',
    context: '1M',
    maxOutput: '32K',
    latency: '320ms',
    description: 'Advanced reasoning at low cost with 1M context',
    best: ['Complex reasoning', 'Long context tasks', 'Code generation', 'Analysis']
  },
  'deepseek-v3': {
    name: 'DeepSeek V3',
    provider: 'DeepSeek',
    input: '0.24',
    output: '1.12',
    context: '128K',
    maxOutput: '16K',
    latency: '320ms',
    description: 'High-quality open-weight model at 17x cheaper than frontier APIs',
    best: ['Code generation', 'Data analysis', 'Content writing', 'RAG applications']
  },
  'claude-sonnet-4.6': {
    name: 'Claude Sonnet 4.6',
    provider: 'Anthropic',
    input: '3.00',
    output: '15.00',
    context: '200K',
    maxOutput: '16K',
    latency: '350ms',
    description: 'Best for writing and balanced reasoning',
    best: ['Creative writing', 'Complex analysis', 'Research', 'Reasoning']
  },
  'gpt-5.4': {
    name: 'GPT-5.4',
    provider: 'OpenAI',
    input: '2.50',
    output: '15.00',
    context: '128K',
    maxOutput: '16K',
    latency: '300ms',
    description: 'Broad tasks and ecosystem compatibility',
    best: ['General purpose', 'Ecosystem apps', 'Agents', 'Tools']
  }
};

export function getStaticPaths() {
  return [
    { params: { slug: 'deepseek-v4-flash' } },
    { params: { slug: 'deepseek-v4-pro' } },
    { params: { slug: 'deepseek-v3' } },
    { params: { slug: 'claude-sonnet-4.6' } },
    { params: { slug: 'gpt-5.4' } }
  ];
}

const slug = Astro.params.slug as keyof typeof models;
const model = models[slug];
---

<BaseLayout title={`${model.name} API — ${model.input} USD per 1M Tokens | BurnCloud`} description={`Access ${model.name} API at ${model.input} USD per 1M input tokens via BurnCloud. OpenAI SDK compatible.`}>
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/models">Models</a>
      <span class="sep">/</span>
      <span class="cur">{model.name}</span>
    </div>
  </nav>

  <main>
    <div class="wrap">
      <div class="layout">
        <article class="article">
          <header class="mhero">
            <div class="mrow">
              <h1>{model.name} API</h1>
              <span class="live">Live</span>
            </div>
            <p class="mdesc">{model.description}</p>
            <div class="mspecs">
              <div class="mspec">
                <span class="mlab">Input</span>
                <span class="mval hl">{model.input} USD/1M</span>
              </div>
              <div class="mspec">
                <span class="mlab">Output</span>
                <span class="mval">{model.output} USD/1M</span>
              </div>
              <div class="mspec">
                <span class="mlab">Context</span>
                <span class="mval">{model.context}</span>
              </div>
              <div class="mspec">
                <span class="mlab">Latency</span>
                <span class="mval">{model.latency}</span>
              </div>
            </div>
          </header>

          <section id="code">
            <h2>Quick start</h2>
            <pre class="code" set:html={`import openai

client = openai.OpenAI(
    base_url="https://api.burncloud.com/v1",
    api_key="your-burncloud-key"
)

response = client.chat.completions.create(
    model="${slug}",
    messages=[{"role": "user", "content": "Hello"}]
)

print(response.choices[0].message.content)`}></pre>
          </section>

          <section id="usecases">
            <h2>Best use cases</h2>
            <div class="uc-grid">
              {model.best.map(use => (
                <div class="uc">
                  <h3>{use}</h3>
                </div>
              ))}
            </div>
          </section>

          <div class="finalcta">
            <h3>Start using {model.name}</h3>
            <p class="cap">OpenAI SDK compatible</p>
            <a href="#" class="btn btn-primary">Get API Key</a>
          </div>
        </article>

        <aside class="sidebar">
          <div class="sbox cta">
            <div class="big">Try {model.name}</div>
            <p class="price">{model.input} USD per 1M tokens</p>
            <a href="#" class="btn btn-primary btn-block">Get API Key</a>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style is:inline>
  .crumb{border-bottom:1px solid var(--border);background:var(--surface);}
  .crumb .wrap{padding:12px 24px;font-size:13px;color:var(--muted);font-family:var(--mono);display:flex;gap:8px;align-items:center;}
  .crumb a:hover{color:var(--text);}
  .crumb .sep{opacity:.5;}
  .crumb .cur{color:var(--text);}
  
  .layout{display:grid;grid-template-columns:1fr 300px;gap:52px;padding:48px 0 40px;align-items:start;}
  
  .mhero{padding-bottom:32px;border-bottom:1px solid var(--border);}
  .mrow{display:flex;align-items:center;gap:16px;}
  .mhero h1{font-size:clamp(32px,5vw,44px);letter-spacing:-.035em;}
  .live{font-family:var(--mono);font-size:11px;font-weight:600;text-transform:uppercase;padding:4px 10px;border-radius:999px;background:var(--green-tint);color:var(--green);}
  .mdesc{color:var(--muted);font-size:18px;margin-top:12px;}
  .mspecs{display:flex;gap:32px;margin-top:24px;flex-wrap:wrap;}
  .mspec{display:flex;flex-direction:column;gap:4px;}
  .mlab{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);}
  .mval{font-family:var(--mono);font-size:20px;font-weight:700;}
  .mval.hl{color:var(--green);}
  
  .article h2{font-size:24px;letter-spacing:-.025em;margin:44px 0 16px;}
  
  pre.code{background:var(--code-bg);padding:22px 24px;font-family:var(--mono);font-size:13px;line-height:1.8;overflow-x:auto;border-radius:12px;margin:20px 0;}
  
  .uc-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:18px 0;}
  .uc{border:1px solid var(--border);border-radius:12px;padding:20px;}
  .uc h3{font-size:16px;}
  
  .finalcta{background:var(--accent-tint);border:1px solid #dfe3ff;border-radius:16px;padding:34px;text-align:center;margin-top:32px;}
  .finalcta h3{font-size:22px;letter-spacing:-.02em;}
  .finalcta .cap{font-family:var(--mono);font-size:13px;color:var(--muted);margin:12px 0 20px;}
  
  .sidebar{position:sticky;top:80px;}
  .sbox{border:1px solid var(--border);border-radius:12px;padding:20px;}
  .sbox.cta{background:var(--accent-tint);border-color:#dfe3ff;text-align:center;}
  .sbox .big{font-size:18px;font-weight:700;letter-spacing:-.02em;}
  .sbox .price{font-family:var(--mono);font-size:13px;color:var(--muted);margin:6px 0 16px;}
  
  @media (max-width:900px){
    .layout{grid-template-columns:1fr;gap:0;}
    .sidebar{position:static;margin-top:44px;}
    .uc-grid{grid-template-columns:1fr;}
  }
</style>