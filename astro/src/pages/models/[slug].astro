---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const models = {
  'deepseek-v4-flash': {
    name: 'DeepSeek V4 Flash',
    provider: 'DeepSeek',
    input: '0.14',
    output: '0.28',
    context: '1M',
    maxOutput: '16K',
    latency: '210ms',
    description: 'The cheapest high-quality LLM with 1M context window',
    best: ['High-throughput agents', 'Bulk data processing', 'Long-document RAG', 'Real-time chat']
  },
  'deepseek-v4-pro': {
    name: 'DeepSeek V4 Pro',
    provider: 'DeepSeek',
    input: '0.435',
    output: '0.87',
    context: '1M',
    maxOutput: '32K',
    latency: '320ms',
    description: 'Advanced reasoning at low cost with 1M context',
    best: ['Complex reasoning', 'Long context tasks', 'Code generation', 'Analysis']
  },
  'deepseek-v3': {
    name: 'DeepSeek V3',
    provider: 'DeepSeek',
    input: '0.24',
    output: '1.12',
    context: '128K',
    maxOutput: '16K',
    latency: '320ms',
    description: 'High-quality open-weight model at 17x cheaper than frontier APIs',
    best: ['Code generation', 'Data analysis', 'Content writing', 'RAG applications']
  },
  'claude-sonnet-4.6': {
    name: 'Claude Sonnet 4.6',
    provider: 'Anthropic',
    input: '3.00',
    output: '15.00',
    context: '200K',
    maxOutput: '16K',
    latency: '350ms',
    description: 'Best for writing and balanced reasoning',
    best: ['Creative writing', 'Complex analysis', 'Research', 'Reasoning']
  },
  'gpt-5.4': {
    name: 'GPT-5.4',
    provider: 'OpenAI',
    input: '2.50',
    output: '15.00',
    context: '128K',
    maxOutput: '16K',
    latency: '300ms',
    description: 'Broad tasks and ecosystem compatibility',
    best: ['General purpose', 'Ecosystem apps', 'Agents', 'Tools']
  }
};

export function getStaticPaths() {
  return [
    { params: { slug: 'deepseek-v4-flash' } },
    { params: { slug: 'deepseek-v4-pro' } },
    { params: { slug: 'deepseek-v3' } },
    { params: { slug: 'claude-sonnet-4.6' } },
    { params: { slug: 'gpt-5.4' } }
  ];
}

const slug = Astro.params.slug as keyof typeof models;
const model = models[slug];
---

<BaseLayout pageStyle="models" title={`${model.name} API — ${model.input} USD per 1M Tokens | BurnCloud`} description={`Access ${model.name} API at ${model.input} USD per 1M input tokens via BurnCloud. OpenAI SDK compatible.`}>
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/models">Models</a>
      <span class="sep">/</span>
      <span class="cur">{model.name}</span>
    </div>
  </nav>

  <main>
    <div class="wrap">
      <div class="layout">
        <article class="article">
          <header class="mhero">
            <div class="mrow">
              <h1>{model.name} API</h1>
              <span class="live">Live</span>
            </div>
            <p class="mdesc">{model.description}</p>
            <div class="mspecs">
              <div class="mspec">
                <span class="mlab">Input</span>
                <span class="mval hl">{model.input} USD/1M</span>
              </div>
              <div class="mspec">
                <span class="mlab">Output</span>
                <span class="mval">{model.output} USD/1M</span>
              </div>
              <div class="mspec">
                <span class="mlab">Context</span>
                <span class="mval">{model.context}</span>
              </div>
              <div class="mspec">
                <span class="mlab">Latency</span>
                <span class="mval">{model.latency}</span>
              </div>
            </div>
          </header>

          <section id="code">
            <h2>Quick start</h2>
            <pre class="code" set:html={`import openai

client = openai.OpenAI(
    base_url="https://api.burncloud.com/v1",
    api_key="your-burncloud-key"
)

response = client.chat.completions.create(
    model="${slug}",
    messages=[{"role": "user", "content": "Hello"}]
)

print(response.choices[0].message.content)`}></pre>
          </section>

          <section id="usecases">
            <h2>Best use cases</h2>
            <div class="uc-grid">
              {model.best.map(use => (
                <div class="uc">
                  <h3>{use}</h3>
                </div>
              ))}
            </div>
          </section>

          <div class="finalcta">
            <h3>Start using {model.name}</h3>
            <p class="cap">OpenAI SDK compatible</p>
            <a href="#" class="btn btn-primary">Get API Key</a>
          </div>
        </article>

        <aside class="sidebar">
          <div class="sbox cta">
            <div class="big">Try {model.name}</div>
            <p class="price">{model.input} USD per 1M tokens</p>
            <a href="#" class="btn btn-primary btn-block">Get API Key</a>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

