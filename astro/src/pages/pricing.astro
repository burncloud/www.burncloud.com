---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const MODELS = [
  { name:"Step 3.5 Flash", slug:"#", prov:"StepFun", input:0.10, output:0.40, ctxLabel:"128K", type:"chinese", official:0.12 },
  { name:"DeepSeek V4 Flash", slug:"/models/deepseek-v4-flash", prov:"DeepSeek", input:0.14, output:0.28, ctxLabel:"128K", type:"chinese", official:0.16 },
  { name:"DeepSeek V3.2", slug:"/models/deepseek-v3", prov:"DeepSeek", input:0.14, output:0.28, ctxLabel:"128K", type:"chinese", official:0.16 },
  { name:"MiniMax", slug:"#", prov:"MiniMax", input:0.32, output:1.28, ctxLabel:"256K", type:"chinese", official:0.36 },
  { name:"Qwen 3.5", slug:"#", prov:"Alibaba", input:0.38, output:1.52, ctxLabel:"128K", type:"chinese", official:0.42 },
  { name:"Doubao Pro", slug:"#", prov:"ByteDance", input:0.42, output:1.68, ctxLabel:"128K", type:"chinese", official:0.47 },
  { name:"DeepSeek V4 Pro", slug:"#", prov:"DeepSeek", input:0.435, output:0.87, ctxLabel:"1M", type:"chinese", official:0.49 },
  { name:"GLM-5.1", slug:"#", prov:"Zhipu", input:0.45, output:1.80, ctxLabel:"256K", type:"chinese", official:0.50 },
  { name:"Kimi K2.6", slug:"#", prov:"Moonshot", input:0.50, output:2.00, ctxLabel:"1M", type:"chinese", official:0.56 },
  { name:"Claude Haiku 4.5", slug:"#", prov:"Anthropic", input:0.25, output:1.25, ctxLabel:"200K", type:"frontier", official:0.25 },
  { name:"Gemini 2.5 Flash", slug:"#", prov:"Google", input:0.30, output:2.50, ctxLabel:"1M", type:"frontier", official:0.30 },
  { name:"Gemini 3.1 Pro", slug:"#", prov:"Google", input:2.00, output:12.00, ctxLabel:"1M", type:"frontier", official:2.20 },
  { name:"GPT-5.4", slug:"#", prov:"OpenAI", input:2.50, output:15.00, ctxLabel:"128K", type:"frontier", official:2.75 },
  { name:"Grok 4.1", slug:"#", prov:"xAI", input:3.00, output:15.00, ctxLabel:"128K", type:"frontier", official:3.30 },
  { name:"Claude Sonnet 4.6", slug:"#", prov:"Anthropic", input:3.00, output:15.00, ctxLabel:"200K", type:"frontier", official:3.30 },
  { name:"Claude Opus 4.7", slug:"#", prov:"Anthropic", input:5.00, output:25.00, ctxLabel:"200K", type:"frontier", official:5.50 },
  { name:"GPT-5.5", slug:"#", prov:"OpenAI", input:5.00, output:30.00, ctxLabel:"128K", type:"frontier", official:5.50 }
];

const fmt = (n) => {
  const r = Math.round(n * 1000);
  return "\$" + (r % 10 === 0 ? (r / 1000).toFixed(2) : (r / 1000).toFixed(3)) + "/1M";
};
---

<BaseLayout pageStyle="pricing" title="LLM API Pricing Calculator 2026 | Compare Claude, GPT, DeepSeek | BurnCloud" description="Calculate your exact LLM API costs. Compare Claude Sonnet 4.6, GPT-5.4, DeepSeek V4 prices. Find the cheapest model for your workload. Pay per token.">
  <Nav />

  <!-- Breadcrumb -->
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="cur">Pricing</span>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="phero" aria-labelledby="p-h1">
      <div class="wrap">
        <h1 id="p-h1">LLM API Pricing Calculator 2026</h1>
        <p>Pay only for what you use. No monthly fees. Credits never expire.</p>
      </div>
    </section>

    <!-- Calculator -->
    <section aria-label="Cost calculator">
      <div class="wrap">
        <div class="calc">
          <div class="calc-grid">
            <div class="calc-inputs">
              <div class="ci-eyebrow">Your workload</div>
              <div class="field">
                <label for="msgs">Messages per day <span class="val" id="msgsVal">5,000</span></label>
                <div class="hint">Drag to match your traffic</div>
                <input type="range" id="msgs" min="100" max="1000000" step="100" value="5000">
              </div>
              <div class="field">
                <label>Average message length</label>
                <div class="hint">Tokens sent + received per message</div>
                <div class="seg" id="lenSeg">
                  <button data-tokens="500" class="active">Short<span class="sm">500</span></button>
                  <button data-tokens="1500">Medium<span class="sm">1,500</span></button>
                  <button data-tokens="4000">Long<span class="sm">4,000</span></button>
                </div>
              </div>
            </div>
            <div class="calc-output">
              <div class="co-eyebrow">Estimated monthly cost</div>
              <div class="co-sub" id="coSub">~150M tokens / month · cheapest highlighted</div>
              <div id="coRows"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Full Price Table -->
    <section class="sec" aria-labelledby="table-h2">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="table-h2">Full Model Pricing Table</h2>
          <p>All prices per 1M tokens. Filter by type or click a column to sort.</p>
        </div>
        <div class="tfilter" id="tfilter">
          <button data-filter="all" class="active">All</button>
          <button data-filter="chinese">Chinese</button>
          <button data-filter="frontier">Frontier</button>
        </div>
        <div class="ptable-wrap">
          <table class="cmp" id="cmpTable">
            <thead>
              <tr>
                <th scope="col" class="sortable" data-key="name" data-type="text">Model <span class="arrow">▲▼</span></th>
                <th scope="col">Provider</th>
                <th scope="col">Type</th>
                <th scope="col" class="num sortable sorted" data-key="input" data-type="num">Input <span class="arrow">▲</span></th>
                <th scope="col" class="num sortable" data-key="output" data-type="num">Output <span class="arrow">▲▼</span></th>
                <th scope="col" class="ctx">Context</th>
                <th scope="col">Details</th>
              </tr>
            </thead>
            <tbody id="cmpBody">
              {MODELS.map(m => (
                <tr class={m.input === 0.10 ? 'cheapest' : ''}>
                  <td class="model">{m.name}</td>
                  <td class="prov">{m.prov}</td>
                  <td><span class="type-tag">{m.type === 'chinese' ? 'Chinese' : 'Frontier'}</span></td>
                  <td class="num">{fmt(m.input)}</td>
                  <td class="num">{fmt(m.output)}</td>
                  <td class="ctx">{m.ctxLabel}</td>
                  <td><a class="dlink" href={m.slug}>View →</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- vs Official -->
    <section class="sec" aria-labelledby="vs-h2">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="vs-h2">BurnCloud vs Paying Official Price</h2>
          <p>BurnCloud routes to the same official APIs — without the reseller markup.</p>
        </div>
        <div class="saving-hero">
          <div class="big">~10%</div>
          <div class="lbl">average saving vs official list prices, across all supported models</div>
        </div>
        <div class="bars" id="bars"></div>
        <div class="barlegend">
          <span><span class="sw" style="background:#94939c"></span> Official price</span>
          <span><span class="sw" style="background:var(--accent)"></span> BurnCloud price</span>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="sec" aria-labelledby="faq-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="faq-h2">Frequently Asked Questions</h2></div>
        <div class="faq">
          <details>
            <summary>How is billing calculated?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Billing is per token, split into input and output. You pay the model's input rate for every token you send and the output rate for every token it returns, metered per 1M tokens. No monthly fees, no seat charges.</div>
          </details>
          <details>
            <summary>Do credits expire?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">No. Credits never expire — whatever you load stays on your balance until you spend it.</div>
          </details>
          <details>
            <summary>Can I get a refund?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Yes. Unused credits are refundable to your original payment method on request.</div>
          </details>
          <details>
            <summary>Is there a free tier?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Creating an account is free and needs no credit card. You add credits only when you're ready to make calls; the minimum top-up is \&#36;5.</div>
          </details>
          <details>
            <summary>What payment methods do you accept?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">All major cards via Stripe. Credits appear on your balance instantly after payment.</div>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="ctasec" id="cta" aria-labelledby="cta-h2">
      <div class="wrap">
        <h2 id="cta-h2">Start Free — No credit card required</h2>
        <div class="btnrow"><a href="#" class="btn btn-primary btn-lg">Create Free Account →</a></div>
        <p class="cap">Credits never expire · Setup in 2 minutes</p>
      </div>
    </section>
  </main>

  <Footer />

  <script define:vars={{ MODELS }}>
    const fmt = (n) => {
      const r = Math.round(n * 1000);
      return "\$" + (r % 10 === 0 ? (r / 1000).toFixed(2) : (r / 1000).toFixed(3)) + "/1M";
    };

    const money = (n) => n >= 100 ? "\$"+n.toLocaleString('en-US',{maximumFractionDigits:0}) : "\$"+n.toFixed(2);

    // Calculator
    const msgs = document.getElementById('msgs');
    const msgsVal = document.getElementById('msgsVal');
    const coRows = document.getElementById('coRows');
    const coSub = document.getElementById('coSub');
    let tokensPerMsg = 500;

    const CALC = ["DeepSeek V4 Flash","Step 3.5 Flash","Claude Sonnet 4.6","GPT-5.4","Gemini 3.1 Pro"];

    function calc() {
      const perDay = +msgs.value;
      msgsVal.textContent = perDay.toLocaleString('en-US');
      const inTok = tokensPerMsg/2, outTok = tokensPerMsg/2;
      const monthlyMsgs = perDay*30;
      const totalTokens = monthlyMsgs*tokensPerMsg;
      coSub.textContent = "~"+ (totalTokens>=1e9 ? (totalTokens/1e9).toFixed(1)+"B" : Math.round(totalTokens/1e6)+"M") +" tokens / month · cheapest highlighted";
      const rows = CALC.map(name => {
        const m = MODELS.find(x => x.name === name);
        const cost = monthlyMsgs*(m.input*inTok + m.output*outTok)/1e6;
        return {m, cost};
      }).sort((a,b) => a.cost - b.cost);
      const min = rows[0].cost;
      coRows.innerHTML = rows.map(r => `
        <div class="corow \${r.cost===min?'cheapest':''}">
          <span class="cm">\${r.m.name} <span class="cprov">\${r.m.prov}</span></span>
          <span class="cprice">\${money(r.cost)}<span style="font-weight:400;color:var(--muted);font-size:12px">/mo</span></span>
        </div>`).join('');
    }

    msgs.addEventListener('input', calc);
    document.querySelectorAll('#lenSeg button').forEach(b => b.addEventListener('click', () => {
      document.querySelectorAll('#lenSeg button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      tokensPerMsg = +b.dataset.tokens;
      calc();
    }));
    calc();

    // Table sorting & filtering
    let sortState = {key:'input', dir:1}, filter='all';
    const tbody = document.getElementById('cmpBody');

    function renderTable() {
      let rows = MODELS.filter(m => filter==='all' || m.type===filter);
      rows = [...rows].sort((a,b) => {
        let av = a[sortState.key], bv = b[sortState.key];
        if (typeof av === 'string') return sortState.dir * av.localeCompare(bv);
        return sortState.dir * (av - bv);
      });
      const minInput = Math.min(...rows.map(r => r.input));
      tbody.innerHTML = rows.map(m => `
        <tr class="\${m.input===minInput?'cheapest':''}">
          <td class="model">\${m.name}</td>
          <td class="prov">\${m.prov}</td>
          <td><span class="type-tag">\${m.type==='chinese'?'Chinese':'Frontier'}</span></td>
          <td class="num">\${fmt(m.input)}</td>
          <td class="num">\${fmt(m.output)}</td>
          <td class="ctx">\${m.ctxLabel}</td>
          <td><a class="dlink" href="\${m.slug}">View →</a></td>
        </tr>`).join('');
      document.querySelectorAll('th.sortable').forEach(th => th.classList.toggle('sorted', th.dataset.key === sortState.key));
    }

    document.querySelectorAll('th.sortable').forEach(th => th.addEventListener('click', () => {
      const key = th.dataset.key;
      if (sortState.key === key) sortState.dir *= -1;
      else { sortState.key = key; sortState.dir = 1; }
      renderTable();
    }));

    document.querySelectorAll('#tfilter button').forEach(b => b.addEventListener('click', () => {
      document.querySelectorAll('#tfilter button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      filter = b.dataset.filter;
      renderTable();
    }));

    // Vs official bars
    const BARS = ["GPT-5.4","Claude Sonnet 4.6","Gemini 3.1 Pro","DeepSeek V4 Flash"];
    const maxOfficial = Math.max(...BARS.map(n => MODELS.find(m => m.name === n).official));
    document.getElementById('bars').innerHTML = BARS.map(name => {
      const m = MODELS.find(x => x.name === name);
      const save = Math.round((1 - m.input/m.official)*100);
      const wo = Math.max(8, m.official/maxOfficial*100);
      const wb = Math.max(8, m.input/maxOfficial*100);
      return `<div class="barrow">
        <div class="bname">\${m.name}<span class="bp">save \${save}%</span></div>
        <div class="bartrack">
          <div class="bar official" style="width:\${wo}%">\${fmt(m.official)}</div>
          <div class="bar bc" style="width:\${wb}%">\${fmt(m.input)}</div>
        </div>
      </div>`;
    }).join('');
  </script>
</BaseLayout>

