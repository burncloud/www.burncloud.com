---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout pageStyle="security" title="Security & Privacy | Zero Logging | Open Source Verified | BurnCloud" description="BurnCloud never logs your requests. Open source code on GitHub. Cryptographically verified deployments. Don't trust us — verify us.">
  <Nav />

  <!-- Breadcrumb -->
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="cur">Security</span>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="shero" aria-labelledby="s-h1">
      <div class="wrap">
        <div class="eyebrow">Security & Privacy</div>
        <h1 id="s-h1">Security you can verify, not just trust.</h1>
        <p class="sub">Don't trust us. Verify us.</p>
        <div class="terminal">
          <div class="term-bar">
            <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
            <span class="term-title">verify.burncloud.com</span>
          </div>
          <div class="term-body" id="term"></div>
        </div>
        <div class="term-actions">
          <a href="#" class="btn btn-outline">View on GitHub <span class="ext">↗</span></a>
          <span class="note">Build it yourself and compare hashes.</span>
        </div>
      </div>
    </section>

    <!-- Zero Logging -->
    <section class="sec" aria-labelledby="log-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="log-h2">Zero request logging</h2></div>
        <p class="lead" style="margin-bottom:22px;">The gateway is a pass-through. It never persists a single byte of your traffic. We never store:</p>
        <ul class="checklist">
          <li><span class="ck">✓</span><span>Your prompts</span></li>
          <li><span class="ck">✓</span><span>Your responses</span></li>
          <li><span class="ck">✓</span><span>Your API usage patterns</span></li>
          <li><span class="ck">✓</span><span>Your IP address</span></li>
        </ul>
        <div class="verify-tip">
          How to verify: search our codebase for <code>log</code> or <code>store</code> — you won't find any request-logging path. The proof is in the source, not in this sentence.
        </div>
      </div>
    </section>

    <!-- Open Source -->
    <section class="sec" aria-labelledby="os-h2">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="os-h2">Fully open source</h2>
          <p>Every line of code that routes your request is public. MIT licensed.</p>
        </div>
        <div class="twocol">
          <div class="info-card"><h3>Read the routing</h3><p>See exactly how requests travel from your app to the official API — no hidden hops.</p></div>
          <div class="info-card"><h3>Verify no logging</h3><p>Confirm for yourself there is no storage or telemetry code anywhere in the path.</p></div>
          <div class="info-card"><h3>Build it yourself</h3><p>Compile from source and reproduce the exact hash that's running in production.</p></div>
          <div class="info-card"><h3>Self-host if you prefer</h3><p>Run the whole gateway on your own infrastructure with one binary.</p></div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="sec" aria-labelledby="arch-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="arch-h2">Direct API connection</h2></div>
        <div class="flow">
          <div class="flow-node"><div class="fn-title">Your App</div></div>
          <div class="flow-arrow" aria-hidden="true">→</div>
          <div class="flow-node verified"><div class="fn-title">BurnCloud</div><div class="fn-sub">✓ verified</div></div>
          <div class="flow-arrow" aria-hidden="true">→</div>
          <div class="flow-node"><div class="fn-title">Official API</div><div class="fn-sub">Claude / GPT / DeepSeek</div></div>
          <div class="flow-arrow" aria-hidden="true">→</div>
          <div class="flow-node"><div class="fn-title">Response</div></div>
        </div>
        <p class="flow-note"><strong>Your request travels one path. No third parties. No black boxes.</strong></p>
      </div>
    </section>

    <!-- Supplier Verification -->
    <section class="sec" aria-labelledby="sup-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="sup-h2">How we verify suppliers</h2></div>
        <ol class="vsteps">
          <li><div><div class="vt">Submit official API account proof</div><div class="vd">Every supplier provides evidence of a genuine, first-party provider account.</div></div></li>
          <li><div><div class="vt">BurnCloud verifies authenticity</div><div class="vd">We confirm the account is real and directly provisioned by the official provider.</div></div></li>
          <li><div><div class="vt">Regular sampling tests</div><div class="vd">Live requests are sampled and checked to confirm the served model matches what was requested.</div></div></li>
          <li><div><div class="vt">Automatic removal on failure</div><div class="vd">Any supplier that fails a sampling test is pulled from rotation immediately.</div></div></li>
        </ol>
      </div>
    </section>

    <!-- Self-host -->
    <section class="sec" aria-labelledby="sh-h2">
      <div class="wrap">
        <div class="sec-head">
          <h2 id="sh-h2">Don't trust us? Self-host.</h2>
          <p>If you prefer complete control, deploy BurnCloud on your own server. Same gateway, your infrastructure.</p>
        </div>
        <a href="#" class="btn btn-outline">Self-host guide <span class="ext">↗</span></a>
      </div>
    </section>

    <!-- Compliance -->
    <section class="sec" aria-labelledby="comp-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="comp-h2">Legal & compliance</h2></div>
        <ul class="compliance">
          <li><span class="dot"></span><span><strong>BurnCloud Ltd.</strong> — UK registered company</span></li>
          <li><span class="dot"></span><span>GDPR compliant</span></li>
          <li><span class="dot"></span><span>Data processing agreement available</span></li>
          <li><span class="dot"></span><span>SOC2 report available on request</span></li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <section class="sec" aria-labelledby="faq-h2">
      <div class="wrap">
        <div class="sec-head"><h2 id="faq-h2">Frequently asked questions</h2></div>
        <div class="faq">
          <details>
            <summary>Does BurnCloud log my prompts or responses?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">No. The gateway stores no prompts, responses, usage patterns, or IP addresses. Because the code is open source, you can search it for any logging or storage path and confirm there is none.</div>
          </details>
          <details>
            <summary>How can I verify what is running?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Call <code>verify.burncloud.com</code> to read the live version, commit, and build hash, then build the same commit yourself and compare the sha256 hash against what's deployed.</div>
          </details>
          <details>
            <summary>Can I self-host BurnCloud?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Yes. BurnCloud is a single Rust binary under an MIT license. Clone the repo, build it, and run it on your own infrastructure for full control.</div>
          </details>
          <details>
            <summary>How are suppliers verified?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">Every supplier submits proof of an official API account, which BurnCloud verifies for authenticity, then runs regular sampling tests and removes any supplier that fails.</div>
          </details>
          <details>
            <summary>Is BurnCloud compliant for enterprise use?<span class="sign" aria-hidden="true">+</span></summary>
            <div class="ans">BurnCloud Ltd. is UK registered and GDPR compliant. A data processing agreement is available, and a SOC2 report is available on request.</div>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="ctasec" aria-labelledby="cta-h2">
      <div class="wrap">
        <h2 id="cta-h2">Read the source code.</h2>
        <p class="repo">github.com/burncloud/burncloud</p>
        <div class="btnrow"><a href="#" class="btn btn-ghost btn-lg">View on GitHub <span class="ext">↗</span></a></div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const term = document.getElementById('term');
    const L = [
      { html:'<span class="prompt">\$</span> <span class="cmd">curl https://verify.burncloud.com</span>', type:true, after:240 },
      { html:'&nbsp;', after:120 },
      { html:'<span class="dim">Checking running version...</span>', after:460 },
      { html:'&nbsp;', after:120 },
      { html:'<span class="key">Version:</span>     <span class="val">v1.2.3</span>', after:110 },
      { html:'<span class="key">Commit:</span>      <span class="val">a1b2c3d</span>', after:110 },
      { html:'<span class="key">Build hash:</span>  <span class="val">sha256:7f3a…</span>', after:110 },
      { html:'<span class="key">Status:</span>      <span class="ok">✓ VERIFIED</span>', after:320 },
      { html:'&nbsp;', after:120 },
      { html:'<span class="dim">This hash matches commit a1b2c3d</span>', after:110 },
      { html:'<span class="dim">on github.com/burncloud/burncloud</span>', after:120, cursor:true }
    ];
    function typeLine(el, html, done){
      const tmp=document.createElement('div'); tmp.innerHTML=html;
      el.classList.add('shown'); const plain=tmp.textContent; let i=0;
      const tick=()=>{ i++; el.textContent=plain.slice(0,i); if(i<plain.length) setTimeout(tick,16); else { el.innerHTML=html; done(); } };
      if(plain.length) tick(); else { el.innerHTML=html; done(); }
    }
    function run(idx){
      if(idx>=L.length) return;
      const item=L[idx]; const line=document.createElement('div'); line.className='term-line'; term.appendChild(line);
      const finish=()=>{ if(item.cursor){ const c=document.createElement('span'); c.className='cursor'; line.appendChild(c);} setTimeout(()=>run(idx+1), item.after||120); };
      if(item.type) typeLine(line, item.html, finish); else { line.classList.add('shown'); line.innerHTML=item.html; finish(); }
    }
    setTimeout(()=>run(0), 400);
  </script>
</BaseLayout>

