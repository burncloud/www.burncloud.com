---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout pageStyle="use-cases" title="BurnCloud for Indie Developers | Cheap LLM API, Pay Per Token | 2026" description="Perfect LLM API for indie developers. Pay per token, no monthly fees, access Claude, GPT, DeepSeek from 0.10 USD per 1M. No commitment. Start free.">
  <Nav />
  
  <nav class="crumb" aria-label="Breadcrumb">
    <div class="wrap">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="cur">Indie Developers</span>
    </div>
  </nav>

  <main>
    <section class="hero">
      <div class="wrap">
        <h1>Pay per token. No monthly fees.</h1>
        <p class="sub">Built for indie developers who ship fast and watch every dollar.</p>
        <div class="btnrow">
          <a href="#" class="btn btn-primary btn-lg">Start Free</a>
          <span class="note">No credit card required</span>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <div class="feat-grid">
          <div class="feat-card">
            <div class="feat-icon">0</div>
            <h3>No monthly minimums</h3>
            <p>Use 1M tokens or 1000M tokens. Same rates. No commitment.</p>
          </div>
          <div class="feat-card">
            <div class="feat-icon">1</div>
            <h3>All models, one key</h3>
            <p>DeepSeek, Claude, GPT, Gemini. Single API. Zero markup.</p>
          </div>
          <div class="feat-card">
            <div class="feat-icon">2</div>
            <h3>Open source SDK</h3>
            <p>Drop-in OpenAI compatible. Migrate in 2 minutes. Self-host if you want.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>Real cost comparison</h2>
        <p class="sec-desc">What you'd pay monthly for typical indie projects.</p>
        <div class="cost-table">
          <div class="cost-row head">
            <div class="cost-cell">Project</div>
            <div class="cost-cell">DeepSeek V4</div>
            <div class="cost-cell">GPT-5.4</div>
          </div>
          <div class="cost-row">
            <div class="cost-cell">Personal chatbot</div>
            <div class="cost-cell hl">0.14 USD</div>
            <div class="cost-cell">25.00 USD</div>
          </div>
          <div class="cost-row">
            <div class="cost-cell">SaaS with AI features</div>
            <div class="cost-cell hl">1.40 USD</div>
            <div class="cost-cell">250.00 USD</div>
          </div>
          <div class="cost-row">
            <div class="cost-cell">AI writing tool</div>
            <div class="cost-cell hl">7.00 USD</div>
            <div class="cost-cell">1,250.00 USD</div>
          </div>
          <div class="cost-row">
            <div class="cost-cell">Code assistant</div>
            <div class="cost-cell hl">0.42 USD</div>
            <div class="cost-cell">17.50 USD</div>
          </div>
        </div>
        <p class="table-note">Based on 10M input + 2M output tokens monthly for SaaS, scaled proportionally for other use cases.</p>
      </div>
    </section>

    <section class="sec">
      <div class="wrap">
        <h2>No lock-in. Ever.</h2>
        <div class="lock-grid">
          <div class="lock-item">
            <h3>Open-source code</h3>
            <p>Our SDK is MIT licensed. Fork it, modify it, self-host it.</p>
          </div>
          <div class="lock-item">
            <h3>Portable data</h3>
            <p>Export your logs anytime. No vendor lock-in on your prompts.</p>
          </div>
          <div class="lock-item">
            <h3>Refund anytime</h3>
            <p>Unused credits refunded within 30 days. No questions asked.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="sec steps-sec">
      <div class="wrap">
        <h2>Start shipping in 60 seconds</h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-num">01</div>
            <h3>Create account</h3>
            <p>Sign up with email. No credit card required to start.</p>
          </div>
          <div class="step-card">
            <div class="step-num">02</div>
            <h3>Add credits</h3>
            <p>Stripe checkout. Credits never expire. 5 USD minimum.</p>
          </div>
          <div class="step-card">
            <div class="step-num">03</div>
            <h3>Ship faster</h3>
            <p>Copy your key, point your OpenAI SDK, deploy.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="ctasec">
      <div class="wrap">
        <h2>Stop overpaying for AI</h2>
        <p class="cap">Join indie developers saving 100x on API costs.</p>
        <div class="btnrow">
          <a href="#" class="btn btn-primary btn-lg">Get Started Free</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

